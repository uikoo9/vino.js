{
  "name": "aibaiban.com",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "prepare": "husky",
    "build": "lerna run build",
    "prettier": "qpro prettier",
    "eslint": "qpro eslint",
    "lint": "npm run build && npm run prettier && npm run eslint",
    "cz": "qpro commitizen",
    "pb": "lerna publish",
    "graph": "nx graph",
    "update": "qpro ncu u && npm --workspaces exec -- qpro ncu u",
    "pkg": "qpro pkg ./packages",
    "dpkg": "qpro pkg ./packages dev",
    "clean": "nx reset",
    "web:dev": "npm run dev -w aibaiban-web",
    "web:build": "npm run build -w aibaiban-web",
    "server:start": "cd configs && shunjs start @shun-js/aibaiban-server",
    "server:build": "npm run pack -w @shun-js/aibaiban-server && npm run upload -w @shun-js/aibaiban-server",
    "go": "npm run web:build && npm run server:build"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "husky": "^9.1.7",
    "lerna": "^9.0.7",
    "lint-staged": "^16.4.0",
    "nx": "^22.5.4",
    "qiao-cos-cli": "^5.0.6",
    "qiao-project": "^5.0.6",
    "qiao-webpack": "^5.0.5"
  }
}
